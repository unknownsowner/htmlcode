  <script>
    function startLoading() {
      document.getElementById("loading-progress").style.width = "100%";
      setTimeout(function() {
        document.getElementById("loading-screen").style.display = "none";
        document.getElementById("game-object").style.display = "block";
      }, 7000);
    }
  </script>
